{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "avbridge": ["./src/index.ts"],
      "@libav.js/variant-webcodecs": ["./src/libav-stubs.d.ts"],
      "libavjs-webcodecs-bridge": ["./src/libav-stubs.d.ts"]
    }
  },
  "include": ["src", "tests", "demo", "tsup.config.ts", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules", "tests/fixtures"]
}
